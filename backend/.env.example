GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=False

# Required for the FastAPI/WebSocket server
APP_NAME=Chopper
AGENT_VOICE=Aoede
LOG_LEVEL=INFO

# Optional local-only bypass for development
# Set to true/1/yes/on if you want to skip Firebase auth temporarily
AUTH_BYPASS=false

# Firebase Admin SDK credentials
# Point this to your service account JSON file
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Optional: if you use GOOGLE_APPLICATION_CREDENTIALS instead
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
